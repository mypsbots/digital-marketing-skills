{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/mypsbots/digital-marketing-skills/schemas/error.schema.json",
  "title": "Error",
  "description": "Common error shape returned by tools and engines.",
  "type": "object",
  "required": ["status", "code", "message"],
  "additionalProperties": false,
  "properties": {
    "status": {
      "type": "string",
      "enum": [
        "insufficient_data",
        "approval_required",
        "policy_blocked",
        "permission_denied",
        "validation_failed",
        "rate_limited",
        "connector_unavailable",
        "failed"
      ]
    },
    "code": { "type": "string" },
    "message": { "type": "string" },
    "details": { "type": "object" },
    "missing_information": { "type": "array", "items": { "type": "string" } },
    "why_it_matters": { "type": "string" },
    "safe_assumptions": { "type": "array", "items": { "type": "string" } },
    "recommended_next_action": { "type": "string" },
    "retryable": { "type": "boolean" },
    "audit_id": { "type": "string" }
  }
}
