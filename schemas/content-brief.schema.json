{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/mypsbots/digital-marketing-skills/schemas/content-brief.schema.json",
  "title": "Content Brief",
  "type": "object",
  "required": ["title", "objective", "audience", "format"],
  "additionalProperties": true,
  "properties": {
    "title": { "type": "string" },
    "objective": { "type": "string" },
    "audience": { "type": "string" },
    "search_intent": {
      "type": "string",
      "enum": ["informational", "navigational", "commercial", "transactional"]
    },
    "primary_keyword": { "type": "string" },
    "secondary_keywords": { "type": "array", "items": { "type": "string" } },
    "format": {
      "type": "string",
      "description": "e.g. blog, pillar, landing-page, ad, email, social-post, video-script"
    },
    "funnel_stage": {
      "type": "string",
      "enum": ["awareness", "consideration", "decision", "retention", "advocacy"]
    },
    "tone_of_voice": { "type": "string" },
    "key_messages": { "type": "array", "items": { "type": "string" } },
    "proof_points": { "type": "array", "items": { "type": "string" } },
    "cta": { "type": "string" },
    "outline": { "type": "array", "items": { "type": "string" } },
    "word_count_target": { "type": "integer", "minimum": 0 },
    "internal_links": { "type": "array", "items": { "type": "string" } },
    "sources_required": { "type": "boolean" },
    "compliance_notes": { "type": "string" },
    "locale": { "type": "string" }
  }
}
