{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/mypsbots/digital-marketing-skills/schemas/connector.schema.json",
  "title": "Connector Capability Descriptor",
  "type": "object",
  "required": ["name", "provider", "auth_method", "read_capabilities", "data_sensitivity"],
  "additionalProperties": true,
  "properties": {
    "name": { "type": "string" },
    "provider": { "type": "string" },
    "category": {
      "type": "string",
      "enum": ["analytics", "advertising", "social", "crm", "email", "commerce", "content", "research", "automation"]
    },
    "auth_method": {
      "type": "string",
      "enum": ["none", "api_key", "oauth2", "service_account", "basic"]
    },
    "required_scopes": { "type": "array", "items": { "type": "string" } },
    "read_capabilities": { "type": "array", "items": { "type": "string" } },
    "write_capabilities": { "type": "array", "items": { "type": "string" } },
    "rate_limits": { "type": "object" },
    "pagination": { "type": "string" },
    "retry_behaviour": { "type": "string" },
    "error_mapping": { "type": "object" },
    "api_version": { "type": "string" },
    "sandbox_available": { "type": "boolean" },
    "data_sensitivity": {
      "type": "string",
      "enum": ["public", "internal", "confidential", "restricted"]
    },
    "approval_requirements": { "type": "array", "items": { "type": "string" } },
    "health_check": { "type": "string" },
    "implementation": { "type": "string", "enum": ["mock", "live"] },
    "last_reviewed": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" }
  }
}
