{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/mypsbots/digital-marketing-skills/schemas/workflow.schema.json",
  "title": "Marketing Workflow",
  "type": "object",
  "required": ["id", "name", "objective", "trigger", "steps"],
  "additionalProperties": true,
  "properties": {
    "id": { "type": "string", "pattern": "^[a-z0-9]+([._-][a-z0-9]+)*$" },
    "name": { "type": "string" },
    "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "objective": { "type": "string" },
    "industries": { "type": "array", "items": { "type": "string" } },
    "trigger": { "type": "string" },
    "required_inputs": { "type": "array", "items": { "type": "string" } },
    "optional_inputs": { "type": "array", "items": { "type": "string" } },
    "preconditions": { "type": "array", "items": { "type": "string" } },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "name", "type"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "type": {
            "type": "string",
            "enum": ["skill", "tool", "decision", "approval_gate", "checkpoint"]
          },
          "ref": { "type": "string" },
          "inputs": { "type": "object" },
          "on_success": { "type": "string" },
          "on_failure": { "type": "string" },
          "approval_required": { "type": "boolean" }
        }
      }
    },
    "decision_points": { "type": "array", "items": { "type": "object" } },
    "approval_gates": { "type": "array", "items": { "type": "string" } },
    "data_dependencies": { "type": "array", "items": { "type": "string" } },
    "failure_paths": { "type": "array", "items": { "type": "string" } },
    "retry_rules": { "type": "object" },
    "rollback_guidance": { "type": "string" },
    "outputs": { "type": "array", "items": { "type": "string" } },
    "kpis": { "type": "array", "items": { "type": "string" } },
    "audit_requirements": { "type": "array", "items": { "type": "string" } }
  }
}
