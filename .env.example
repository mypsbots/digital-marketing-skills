# ---------------------------------------------------------------------------
# Digital Marketing Skills MCP - environment configuration example
# Copy to .env and fill in values. NEVER commit a real .env file.
# All secrets are read from environment variables only.
# ---------------------------------------------------------------------------

# Server
DM_MCP_TRANSPORT=stdio            # stdio | http
DM_MCP_HTTP_PORT=8080
DM_MCP_HTTP_HOST=127.0.0.1
# Optional bearer token. When set, POST /mcp requires: Authorization: Bearer <token>.
# Strongly recommended for any publicly hosted (HTTPS) deployment. /health stays open.
DM_MCP_HTTP_AUTH_TOKEN=
DM_MCP_LOG_LEVEL=info             # debug | info | warn | error
DM_MCP_LOG_FORMAT=json            # json | pretty

# Safety defaults
DM_MCP_READ_ONLY=true             # when true, write tools are disabled entirely
DM_MCP_WRITE_DRY_RUN_DEFAULT=true # write tools default to dry-run
DM_MCP_REQUIRE_APPROVAL=true      # enforce approval engine for high-risk actions

# Skills / content
DM_MCP_SKILLS_DIR=./skills
DM_MCP_WORKFLOWS_DIR=./workflows
DM_MCP_RESOURCES_DIR=./resources
DM_MCP_TEMPLATES_DIR=./templates

# Regional / locale defaults (make locale, currency and timezone explicit)
DM_MCP_DEFAULT_LOCALE=en-GB
DM_MCP_DEFAULT_CURRENCY=GBP
DM_MCP_DEFAULT_TIMEZONE=Europe/London

# ---------------------------------------------------------------------------
# Connector credentials (ONLY used by live connectors; mock connectors ignore).
# Leave blank to use mock connectors. Never place real keys in source control.
# ---------------------------------------------------------------------------
# Google Analytics 4
GA4_PROPERTY_ID=
GA4_SERVICE_ACCOUNT_JSON=

# Google Ads
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=

# Meta (Facebook/Instagram) Ads
META_ADS_ACCESS_TOKEN=
META_ADS_ACCOUNT_ID=

# HubSpot CRM
HUBSPOT_ACCESS_TOKEN=

# Email service provider (generic)
ESP_API_KEY=

# Feature flags
DM_MCP_ENABLE_LIVE_CONNECTORS=false
